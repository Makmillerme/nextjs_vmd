# Скопіюйте цей файл як `.env` і підставте свої значення. Секрети не комітити.
#
# Локальний PostgreSQL (приклад — замініть USER, PASSWORD, DATABASE_NAME):
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME"
#
# Prisma Postgres / інший провайдер (якщо використовуєте):
# DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."

# Власник (один на систему). Seed: npm run db:seed. Передача прав — через UI.
# OWNER_EMAIL="owner@example.com"
# OWNER_PASSWORD="your-secure-password"
